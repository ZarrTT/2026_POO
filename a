from dataclasses import dataclass
from datetime import datetime

@dataclass
class Usuario:
    login: str
    senha: str
    perfil: str


@dataclass
class Produto:
    id: int
    nome: str
    preco: float
    estoque: int
    categoria: str


@dataclass
class ItemCarrinho:
    produto: Produto
    quantidade: int


@dataclass
class Compra:
    cliente: str
    itens: list
    data: str
    valor_total: float

class SistemaEcommerce:

    def __init__(self):

        self.usuarios = {}
        self.produtos = {}

        self.carrinhos = {}

        self.vendas = []

        self.criar_admin()
        self.criar_produtos_exemplo()


    def criar_admin(self):

        admin = Usuario(
            login="admin",
            senha="123",
            perfil="admin"
        )

        self.usuarios[admin.login] = admin

    def criar_produtos_exemplo(self):

        produtos = [
            Produto(1, "Notebook", 3500, 10, "Informática"),
            Produto(2, "Mouse", 80, 20, "Informática"),
            Produto(3, "Teclado", 150, 15, "Informática"),
            Produto(4, "Monitor", 900, 8, "Informática")
        ]

        for p in produtos:
            self.produtos[p.id] = p

    def abrir_conta(self):

        print("\n=== ABRIR CONTA ===")

        login = input("Login: ")

        if login in self.usuarios:
            print("Usuário já existe.")
            return

        senha = input("Senha: ")

        usuario = Usuario(login, senha, "cliente")

        self.usuarios[login] = usuario

        print("Conta criada com sucesso!")

    def entrar_sistema(self):

        print("\n=== LOGIN ===")

        login = input("Login: ")
        senha = input("Senha: ")

        usuario = self.usuarios.get(login)

        if usuario and usuario.senha == senha:

            print(f"\nBem-vindo {usuario.login}")

            if usuario.perfil == "admin":
                self.menu_admin(usuario)

            else:
                self.menu_cliente(usuario)

        else:
            print("Login inválido.")

    def sair_sistema(self):
        print("Saindo do sistema...")

    def listar_produtos(self):

        print("\n=== PRODUTOS ===")

        for produto in self.produtos.values():

            print(
                f"ID: {produto.id} | "
                f"{produto.nome} | "
                f"Categoria: {produto.categoria} | "
                f"Preço: R$ {produto.preco:.2f} | "
                f"Estoque: {produto.estoque}"
            )

    def cadastrar_produto(self):

        print("\n=== CADASTRAR PRODUTO ===")

        try:

            id_produto = int(input("ID: "))
            nome = input("Nome: ")
            preco = float(input("Preço: "))
            estoque = int(input("Estoque: "))
            categoria = input("Categoria: ")

            if id_produto in self.produtos:
                print("Produto já existe.")
                return

            produto = Produto(
                id_produto,
                nome,
                preco,
                estoque,
                categoria
            )

            self.produtos[id_produto] = produto

            print("Produto cadastrado.")

        except:
            print("Erro ao cadastrar produto.")

    def reajustar_preco(self):

        print("\n=== REAJUSTAR PREÇO ===")

        try:

            id_produto = int(input("ID do produto: "))

            produto = self.produtos.get(id_produto)

            if not produto:
                print("Produto não encontrado.")
                return

            novo_preco = float(input("Novo preço: "))

            produto.preco = novo_preco

            print("Preço atualizado.")

        except:
            print("Erro.")

    def inserir_carrinho(self, usuario):

        self.listar_produtos()

        try:

            id_produto = int(input("\nID do produto: "))
            quantidade = int(input("Quantidade: "))

            produto = self.produtos.get(id_produto)

            if not produto:
                print("Produto não encontrado.")
                return

            if quantidade > produto.estoque:
                print("Estoque insuficiente.")
                return

            if usuario.login not in self.carrinhos:
                self.carrinhos[usuario.login] = []

            carrinho = self.carrinhos[usuario.login]

            for item in carrinho:

                if item.produto.id == produto.id:
                    item.quantidade += quantidade
                    print("Quantidade atualizada.")
                    return

            item = ItemCarrinho(produto, quantidade)

            carrinho.append(item)

            print("Produto inserido.")

        except:
            print("Erro.")


    def visualizar_carrinho(self, usuario):

        print("\n=== CARRINHO ===")

        carrinho = self.carrinhos.get(usuario.login, [])

        if not carrinho:
            print("Carrinho vazio.")
            return

        total_geral = 0

        for item in carrinho:

            preco_unitario = item.produto.preco
            subtotal = preco_unitario * item.quantidade

            total_geral += subtotal

            print(
                f"\nProduto: {item.produto.nome}"
            )

            print(
                f"Preço Unitário: R$ {preco_unitario:.2f}"
            )

            print(
                f"Quantidade: {item.quantidade}"
            )

            print(
                f"Total Item: R$ {subtotal:.2f}"
            )

        print(f"\nTOTAL CARRINHO: R$ {total_geral:.2f}")


    def comprar_carrinho(self, usuario):

        carrinho = self.carrinhos.get(usuario.login, [])

        if not carrinho:
            print("Carrinho vazio.")
            return

        total = 0

        for item in carrinho:

            item.produto.estoque -= item.quantidade

            total += item.produto.preco * item.quantidade

        compra = Compra(
            cliente=usuario.login,
            itens=carrinho.copy(),
            data=str(datetime.now()),
            valor_total=total
        )

        self.vendas.append(compra)

        self.carrinhos[usuario.login] = []

        print(f"Compra realizada. Total: R$ {total:.2f}")


    def listar_minhas_compras(self, usuario):

        print("\n=== MINHAS COMPRAS ===")

        encontrou = False

        for compra in self.vendas:

            if compra.cliente == usuario.login:

                encontrou = True

                print("\n-------------------")
                print(f"Data: {compra.data}")

                for item in compra.itens:

                    print(
                        f"{item.produto.nome} | "
                        f"Qtd: {item.quantidade}"
                    )

                print(
                    f"Total: R$ {compra.valor_total:.2f}"
                )

        if not encontrou:
            print("Nenhuma compra encontrada.")

    def listar_vendas(self):

        print("\n=== VENDAS DO SISTEMA ===")

        if not self.vendas:
            print("Nenhuma venda realizada.")
            return

        for compra in self.vendas:

            print("\n====================")
            print(f"Cliente: {compra.cliente}")
            print(f"Data: {compra.data}")

            for item in compra.itens:

                print(
                    f"{item.produto.nome} | "
                    f"Qtd: {item.quantidade}"
                )

            print(
                f"Valor Total: R$ {compra.valor_total:.2f}"
            )

    def menu_cliente(self, usuario):

        while True:

            print("""

======== MENU CLIENTE ========

1 - Listar produtos
2 - Inserir produto no carrinho
3 - Visualizar carrinho
4 - Comprar carrinho
5 - Listar minhas compras
0 - Sair
""")

            opcao = input("Escolha: ")

            if opcao == "1":
                self.listar_produtos()

            elif opcao == "2":
                self.inserir_carrinho(usuario)

            elif opcao == "3":
                self.visualizar_carrinho(usuario)

            elif opcao == "4":
                self.comprar_carrinho(usuario)

            elif opcao == "5":
                self.listar_minhas_compras(usuario)

            elif opcao == "0":
                self.sair_sistema()
                break

            else:
                print("Opção inválida.")

    def menu_admin(self, usuario):

        while True:

            print("""

======== MENU ADMIN ========

1 - Listar produtos
2 - Cadastrar produto
3 - Reajustar preço
4 - Listar vendas
0 - Sair
""")

            opcao = input("Escolha: ")

            if opcao == "1":
                self.listar_produtos()

            elif opcao == "2":
                self.cadastrar_produto()

            elif opcao == "3":
                self.reajustar_preco()

            elif opcao == "4":
                self.listar_vendas()

            elif opcao == "0":
                self.sair_sistema()
                break

            else:
                print("Opção inválida.")

    def iniciar(self):

        while True:

            print("""

================================
SISTEMA DE E-COMMERCE
================================

1 - Abrir conta
2 - Entrar no sistema
0 - Encerrar
""")

            opcao = input("Escolha: ")

            if opcao == "1":
                self.abrir_conta()

            elif opcao == "2":
                self.entrar_sistema()

            elif opcao == "0":
                print("Sistema encerrado.")
                break

            else:
                print("Opção inválida.")

sistema = SistemaEcommerce()
sistema.iniciar()
